{
  "name": "onnx2anything",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Convert ONNX models to NCNN, MNN, TNN, TFLite, PaddleLite entirely in your browser using WebAssembly",
  "keywords": ["onnx", "model-conversion", "wasm", "webassembly", "ncnn", "mnn", "tnn", "tflite", "coreml", "paddlelite", "edge-inference", "browser", "pyodide", "neural-network", "deep-learning"],
  "scripts": {
    "dev": "npm run build:wasm && cd apps/web && vite",
    "build": "npm run build:toolchains && npm run build:wasm && cd apps/web && vite build",
    "build:wasm": "cd packages/wasm-converter && npm run build && cd ../.. && node scripts/sync-wasm-converter-assets.mjs",
    "sync:wasm": "node scripts/sync-wasm-converter-assets.mjs",
    "build:toolchains": "bash scripts/build-edge-toolchains.sh",
    "build:toolchains:manifest": "node scripts/generate-toolchain-manifest.mjs",
    "build:toolchain:ncnn": "bash scripts/build-edge-toolchain.sh ncnn",
    "build:toolchain:mnn": "bash scripts/build-edge-toolchain.sh mnn",
    "build:toolchain:openvino": "bash scripts/build-edge-toolchain.sh openvino",
    "build:toolchain:paddlelite": "bash scripts/build-edge-toolchain.sh paddlelite",
    "build:toolchain:tnn": "bash scripts/build-edge-toolchain.sh tnn",
    "build:paddlelite:opt:native": "node scripts/build-paddlelite-opt-native.mjs",
    "export:tflite:native": "node scripts/export-tflite-artifacts-native.mjs",
    "export:paddlelite:native": "node scripts/export-paddlelite-artifacts-native.mjs",
    "export:openvino:native": "node scripts/export-openvino-artifacts-native.mjs",
    "test:smoke:tflite:native": "node scripts/smoke_tflite_native_export.mjs",
    "test:smoke:paddlelite:native": "node scripts/smoke_paddlelite_native_export.mjs",
    "test:smoke:paddlelite:opt:wasm": "node scripts/verify-paddlelite-opt.mjs",
    "test:probe:paddlelite:front-half": "node scripts/probe-paddlelite-front-half.mjs",
    "test:smoke:openvino:native": "node scripts/smoke_openvino_native_export.mjs",
    "test:smoke:openvino:python": "python3 scripts/smoke_openvino_python_converter.py",
    "test:smoke:converter-capabilities": "python3 scripts/smoke_converter_capabilities.py",
    "test:smoke:edge:baseline": "node scripts/smoke_edge_frameworks_baseline.mjs",
    "test:smoke:edge:real-model": "node scripts/smoke_edge_frameworks_baseline.mjs --real-model",
    "test:compare:edge:baseline": "node scripts/compare_edge_framework_outputs.mjs",
    "test:compare:edge:real-model": "node scripts/compare_edge_framework_outputs.mjs --real-model",
    "test:smoke:wasm-sync": "node scripts/check-wasm-converter-sync.mjs",
    "preview": "cd apps/web && vite preview",
    "test": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:e2e": "playwright test tests/e2e",
    "test:e2e:ui": "playwright test tests/e2e --ui",
    "test:perf": "vitest run tests/perf",
    "test:yolo": "vitest run tests/unit -t YOLO",
    "test:model": "bash scripts/run-tests.sh model",
    "test:all": "bash scripts/run-tests.sh all",
    "test:compare:ncnn": "bash scripts/run-onnx-ncnn-compare.sh",
    "test:compare:dbnet": "bash scripts/run-dbnet-ncnn-compare.sh",
    "export:mnn:auto": "node scripts/export-mnn-artifacts.mjs --fallback-native",
    "export:mnn:native": "node scripts/export-mnn-artifacts-native.mjs",
    "test:smoke:mnn:auto": "node scripts/smoke_dbnet_mnn_auto_export.mjs",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --ui",
    "test:fixtures": "python3 tests/fixtures/generate_dummy_models.py --output-dir tests/fixtures",
    "lint": "eslint . --ext ts,tsx",
    "docker:dev": "docker-compose -f docker/dev.yml up -d",
    "docker:build": "docker-compose -f docker/dev.yml build",
    "docker:toolchain:all": "bash scripts/docker-build-toolchain.sh all",
    "docker:toolchain:ncnn": "bash scripts/docker-build-toolchain.sh ncnn",
    "docker:toolchain:mnn": "bash scripts/docker-build-toolchain.sh mnn",
    "docker:toolchain:openvino": "bash scripts/docker-build-toolchain.sh openvino",
    "docker:toolchain:paddlelite": "bash scripts/docker-build-toolchain.sh paddlelite",
    "dev:desktop": "cd apps/desktop && npm run dev",
    "build:desktop": "cd apps/desktop && npm run build",
    "pack:dmg": "cd apps/desktop && npm run pack:dmg"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.0",
    "@testing-library/jest-dom": "^6.3.0",
    "@testing-library/react": "^14.1.2",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/testing-library__jest-dom": "^6.0.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "happy-dom": "^13.3.0",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.11",
    "vitest": "^1.2.1"
  },
  "dependencies": {
    "comlink": "^4.4.1",
    "pyodide": "^0.25.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.2.3",
    "sonner": "^1.3.1"
  }
}
